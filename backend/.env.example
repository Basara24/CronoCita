# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados (MySQL)
DATABASE_URL="mysql://cronocita:cronocita@localhost:3306/cronocita"

# Autenticação
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Notificações (providers desacoplados - stubs)
NOTIFICATION_PROVIDER=whatsapp   # whatsapp | twilio | evolution
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
