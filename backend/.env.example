# Servidor
PORT=3333
NODE_ENV=development

# Banco de dados (MySQL do Docker, exposto no host na porta 3307)
# Mesmo banco acessível pelo DBeaver: host=localhost porta=3307 user=cronocita senha=cronocita
DATABASE_URL="mysql://cronocita:cronocita@localhost:3307/cronocita"

# Autenticação
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=7

# Notificações — Evolution API (WhatsApp automático; chat in-app permanece no portal)
# NOTIFICATION_PROVIDER=evolution | whatsapp | twilio
NOTIFICATION_PROVIDER=evolution
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=change-me-evolution-key
EVOLUTION_INSTANCE=cronocita

# Alternativas
WHATSAPP_API_URL=
WHATSAPP_API_TOKEN=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Seed: defina true para recriar dados demo (apaga conteúdo existente)
# FORCE_SEED=false
