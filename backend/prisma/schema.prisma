generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SECRETARY
  PROFESSIONAL
  PATIENT
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELED
  FINISHED
  NO_SHOW
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationEvent {
  APPOINTMENT_CREATED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(SECRETARY)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  patient             Patient?
  professional        Professional?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Patient {
  id        String   @id @default(uuid())
  name      String
  cpf       String   @unique
  email     String   @unique
  phone     String
  birthDate DateTime
  address   String?
  city      String?
  state     String?
  zipCode   String?
  userId    String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@map("patients")
}

model Professional {
  id                   String   @id @default(uuid())
  name                 String
  specialty            String
  commissionPercentage Decimal  @db.Decimal(5, 2)
  phone                String
  email                String   @unique
  userId               String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]
  commissions  Commission[]

  @@map("professionals")
}

model Room {
  id          String         @id @default(uuid())
  name        String
  description String?
  capacity    Int            @default(1)
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  appointments Appointment[]

  @@map("rooms")
}

model Equipment {
  id          String         @id @default(uuid())
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  appointments Appointment[]
  services     ServiceEquipment[]

  @@map("equipments")
}

model Service {
  id              String   @id @default(uuid())
  name            String
  durationMinutes Int
  price           Decimal  @db.Decimal(10, 2)
  requiresRoom    Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  equipments   ServiceEquipment[]
  appointments Appointment[]

  @@map("services")
}

model ServiceEquipment {
  serviceId   String
  equipmentId String

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([serviceId, equipmentId])
  @@map("service_equipments")
}

model Appointment {
  id             String            @id @default(uuid())
  patientId      String
  professionalId String
  serviceId      String
  roomId         String?
  equipmentId    String?
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(SCHEDULED)
  rating         Int?
  notes          String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  patient      Patient        @relation(fields: [patientId], references: [id])
  professional Professional   @relation(fields: [professionalId], references: [id])
  service      Service        @relation(fields: [serviceId], references: [id])
  room         Room?          @relation(fields: [roomId], references: [id])
  equipment    Equipment?     @relation(fields: [equipmentId], references: [id])
  commission   Commission?
  notifications Notification[]

  @@index([professionalId, startsAt])
  @@index([roomId, startsAt])
  @@index([equipmentId, startsAt])
  @@index([patientId, startsAt])
  @@map("appointments")
}

model Commission {
  id                String   @id @default(uuid())
  appointmentId     String   @unique
  professionalId    String
  totalValue        Decimal  @db.Decimal(10, 2)
  percentage        Decimal  @db.Decimal(5, 2)
  professionalValue Decimal  @db.Decimal(10, 2)
  clinicValue       Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([professionalId])
  @@map("commissions")
}

model Notification {
  id            String              @id @default(uuid())
  appointmentId String?
  recipient     String
  channel       NotificationChannel @default(WHATSAPP)
  event         NotificationEvent
  status        NotificationStatus  @default(PENDING)
  message       String              @db.Text
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@map("notifications")
}
