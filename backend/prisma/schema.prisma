generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  CLINIC_ADMIN
  SECRETARY
  PROFESSIONAL
  PATIENT
}

enum ClinicStatus {
  ACTIVE
  INACTIVE
}

enum SubscriptionPlan {
  BASIC
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
}

enum ResourceStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  CANCELED
  FINISHED
  NO_SHOW
}

enum NotificationChannel {
  WHATSAPP
  SMS
  EMAIL
}

enum NotificationEvent {
  APPOINTMENT_CREATED
  APPOINTMENT_REMINDER
  APPOINTMENT_CANCELED
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum NotificationType {
  APPOINTMENT
  REMINDER
  CHAT
  PROMOTION
  SYSTEM
}

enum ClinicPhotoCategory {
  RECEPTION
  CONSULTORIO
  EQUIPMENT
  TEAM
  FACADE
  OTHER
}

enum ContactStatus {
  NEW
  READ
  RESOLVED
}

model Clinic {
  id            String       @id @default(uuid())
  name          String
  slug          String       @unique
  cnpj          String       @unique
  email         String
  phone         String
  description   String?      @db.Text
  logoUrl       String?
  coverImageUrl String?
  website       String?
  instagram     String?
  facebook      String?
  address       String
  city          String
  state         String
  zipCode       String
  latitude      Decimal?     @db.Decimal(10, 7)
  longitude     Decimal?     @db.Decimal(10, 7)
  rating        Decimal?     @db.Decimal(3, 2)
  status        ClinicStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  specialties   ClinicSpecialty[]
  subscription  Subscription?
  users         User[]
  professionals Professional[]
  patients      Patient[]
  rooms         Room[]
  equipments    Equipment[]
  services      Service[]
  appointments  Appointment[]
  commissions   Commission[]
  photos        ClinicPhoto[]
  favorites     Favorite[]

  @@index([city])
  @@map("clinics")
}

model ClinicPhoto {
  id        String              @id @default(uuid())
  clinicId  String
  url       String
  category  ClinicPhotoCategory @default(OTHER)
  caption   String?
  createdAt DateTime            @default(now())

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@index([clinicId])
  @@map("clinic_photos")
}

model ClinicSpecialty {
  clinicId  String
  specialty String

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@id([clinicId, specialty])
  @@index([specialty])
  @@map("clinic_specialties")
}

model Subscription {
  id        String             @id @default(uuid())
  clinicId  String             @unique
  plan      SubscriptionPlan   @default(BASIC)
  status    SubscriptionStatus @default(ACTIVE)
  price     Decimal            @db.Decimal(10, 2)
  startsAt  DateTime           @default(now())
  renewsAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  cpf       String?  @unique
  phone     String?
  avatarUrl String?
  password  String
  role      Role     @default(SECRETARY)
  clinicId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic              Clinic?              @relation(fields: [clinicId], references: [id], onDelete: SetNull)
  patients            Patient[]
  professional        Professional?
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  notifications       UserNotification[]
  sentMessages        Message[]            @relation("MessageSender")
  receivedMessages    Message[]            @relation("MessageReceiver")
  favorites           Favorite[]

  @@index([clinicId])
  @@map("users")
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  clinicId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  clinic Clinic @relation(fields: [clinicId], references: [id], onDelete: Cascade)

  @@unique([userId, clinicId])
  @@index([userId])
  @@map("favorites")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model Patient {
  id        String   @id @default(uuid())
  clinicId  String
  name      String
  cpf       String
  email     String
  phone     String
  birthDate DateTime
  address   String?
  city      String?
  state     String?
  zipCode   String?
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@unique([clinicId, cpf])
  @@unique([clinicId, email])
  @@index([clinicId])
  @@index([userId])
  @@map("patients")
}

model Professional {
  id                   String   @id @default(uuid())
  clinicId             String
  name                 String
  specialty            String
  commissionPercentage Decimal  @db.Decimal(5, 2)
  phone                String
  email                String
  userId               String?  @unique
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  clinic         Clinic          @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  user           User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  appointments   Appointment[]
  commissions    Commission[]
  services       Service[]
  scheduleBlocks ScheduleBlock[]

  @@unique([clinicId, email])
  @@index([clinicId])
  @@map("professionals")
}

model ScheduleBlock {
  id             String   @id @default(uuid())
  professionalId String
  clinicId       String
  startsAt       DateTime
  endsAt         DateTime
  reason         String?
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, startsAt])
  @@map("schedule_blocks")
}

model Room {
  id          String         @id @default(uuid())
  clinicId    String
  name        String
  description String?
  capacity    Int            @default(1)
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  clinic       Clinic        @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([clinicId])
  @@map("rooms")
}

model Equipment {
  id          String         @id @default(uuid())
  clinicId    String
  name        String
  description String?
  status      ResourceStatus @default(ACTIVE)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  clinic       Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  services     ServiceEquipment[]

  @@index([clinicId])
  @@map("equipments")
}

model Service {
  id              String         @id @default(uuid())
  clinicId        String
  professionalId  String?
  name            String
  description     String?        @db.Text
  durationMinutes Int
  price           Decimal        @db.Decimal(10, 2)
  imageUrl        String?
  requiresRoom    Boolean        @default(true)
  status          ResourceStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  clinic       Clinic             @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  professional Professional?      @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  equipments   ServiceEquipment[]
  appointments Appointment[]

  @@index([clinicId])
  @@index([professionalId])
  @@map("services")
}

model ServiceEquipment {
  serviceId   String
  equipmentId String

  service   Service   @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  equipment Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)

  @@id([serviceId, equipmentId])
  @@map("service_equipments")
}

model Appointment {
  id             String            @id @default(uuid())
  clinicId       String
  patientId      String
  professionalId String
  serviceId      String
  roomId         String?
  equipmentId    String?
  startsAt       DateTime
  endsAt         DateTime
  status         AppointmentStatus @default(SCHEDULED)
  rating         Int?
  notes          String?           @db.Text
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  clinic        Clinic         @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  patient       Patient        @relation(fields: [patientId], references: [id])
  professional  Professional   @relation(fields: [professionalId], references: [id])
  service       Service        @relation(fields: [serviceId], references: [id])
  room          Room?          @relation(fields: [roomId], references: [id])
  equipment     Equipment?     @relation(fields: [equipmentId], references: [id])
  commission    Commission?
  notifications Notification[]

  @@index([clinicId, startsAt])
  @@index([professionalId, startsAt])
  @@index([roomId, startsAt])
  @@index([equipmentId, startsAt])
  @@index([patientId, startsAt])
  @@map("appointments")
}

model Commission {
  id                String   @id @default(uuid())
  clinicId          String
  appointmentId     String   @unique
  professionalId    String
  totalValue        Decimal  @db.Decimal(10, 2)
  percentage        Decimal  @db.Decimal(5, 2)
  professionalValue Decimal  @db.Decimal(10, 2)
  clinicValue       Decimal  @db.Decimal(10, 2)
  createdAt         DateTime @default(now())

  clinic       Clinic       @relation(fields: [clinicId], references: [id], onDelete: Cascade)
  appointment  Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id])

  @@index([clinicId])
  @@index([professionalId])
  @@map("commissions")
}

model Notification {
  id            String              @id @default(uuid())
  appointmentId String?
  recipient     String
  channel       NotificationChannel @default(WHATSAPP)
  event         NotificationEvent
  status        NotificationStatus  @default(PENDING)
  message       String              @db.Text
  sentAt        DateTime?
  createdAt     DateTime            @default(now())

  appointment Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([appointmentId])
  @@map("notifications")
}

model UserNotification {
  id            String           @id @default(uuid())
  userId        String
  title         String
  message       String           @db.Text
  type          NotificationType @default(SYSTEM)
  isRead        Boolean          @default(false)
  appointmentId String?
  createdAt     DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("user_notifications")
}

model Message {
  id            String    @id @default(uuid())
  senderId      String
  receiverId    String
  appointmentId String?
  content       String    @db.Text
  attachmentUrl String?
  isImportant   Boolean   @default(false)
  createdAt     DateTime  @default(now())
  readAt        DateTime?

  sender   User @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver User @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId, receiverId])
  @@index([receiverId, senderId])
  @@map("messages")
}

model Contact {
  id        String        @id @default(uuid())
  name      String
  email     String
  subject   String
  message   String        @db.Text
  status    ContactStatus @default(NEW)
  createdAt DateTime      @default(now())

  @@index([status])
  @@map("contacts")
}
